# Copy to .env and fill in. .env is gitignored (never committed).

# Admin (Cheftyz) — seeded on first server start
ADMIN_EMAIL=you@example.com
ADMIN_PASSWORD=change-me
ADMIN_NAME=Cheftyz

# Port the server listens on
PORT=8787

# Persistent storage (recommended for hosting). Paste a Postgres connection string
# from a free Neon (neon.tech) or Supabase database. Without it, data is stored in
# a local JSON file (fine locally, but resets on hosts with no persistent disk).
# DATABASE_URL=postgres://user:pass@host/dbname?sslmode=require

# Email for password-reset codes (optional).
# Without these, reset codes are printed to the server console instead of emailed.
# Example for Gmail: create an "App Password" and use it as SMTP_PASS.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASS=your-app-password
# MAIL_FROM=MB Chatters <you@gmail.com>
